# Interview Story Coach - Environment Variables
# Copy this file to .env and fill in your credentials

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Notion API Key
# Get from: https://www.notion.so/my-integrations
# 1. Create new integration
# 2. Give it a name (e.g., "Interview Coach")
# 3. Copy the "Internal Integration Token" (starts with "noti_")
NOTION_API_KEY=noti_...

# Notion FIT STORIES Page ID
# Open your FIT STORIES page in Notion
# The URL looks like: https://www.notion.so/xxx/FIT-STORIES-abcd1234efgh5678ijkl9012mnop3456
# The page ID is the last 32 characters (after the dash): abcd1234efgh5678ijkl9012mnop3456
NOTION_FIT_STORIES_PAGE_ID=abcd1234efgh5678ijkl9012mnop3456
